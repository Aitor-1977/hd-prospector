# hd-prospector — configuración (todas opcionales; hay defaults para dev local)

# Base de datos.
#   - Producción: PostgreSQL. Basta con conectar la base en Vercel; inyecta
#     DATABASE_URL / POSTGRES_URL y el motor las detecta solo.
#   - Override explícito (scraper en host aparte): descomenta y pon tu cadena.
#   - Desarrollo/tests: SQLite (default).
# HD_DATABASE_URL=postgres://usuario:password@host/db?sslmode=require
HD_DATABASE_URL=sqlite:///data/hd_scraper.db

# Retención del crudo comprimido en disco (días).
HD_RAW_RETENTION_DAYS=90

# Scheduler: cada cuántas horas corre.
HD_SCHEDULE_HOURS=12

# Gobernanza: rate limiting / backoff por fuente.
HD_REQUEST_TIMEOUT_S=20
HD_MAX_RETRIES=4
HD_BACKOFF_BASE_S=2
HD_MIN_INTERVAL_S=1.5

# Salud: fallos consecutivos que disparan alerta.
HD_HEALTH_ALERT_THRESHOLD=2

# Token para el alta de prospectos (POST /prospectos y pantalla /admin).
# Si queda vacío, la escritura está DESHABILITADA (API solo lectura).
# Elige una cadena larga y secreta.
HD_INGEST_TOKEN=

# Empresas seguidas por el scheduler (coma-separadas).
HD_TRACKED_EMPRESAS=

# Slugs de job boards por empresa: "Empresa=slug,Empresa2=slug2".
# El scheduler solo consulta job boards para empresas con slug configurado.
HD_TRACKED_SLUGS=

# User-Agent identificable.
HD_USER_AGENT=hd-scraper/0.1 (+https://hamaca.digital; evidence-extraction)

# ── Conectores de ingesta Capa 0 (noticias RSS gratis / yt-dlp → /webhook/ingesta) ──
# Destino del webhook (backend de hd-prospector).
HD_WEBHOOK_URL=https://hd-prospector.vercel.app/webhook/ingesta
# El webhook usa el mismo HD_INGEST_TOKEN de arriba (no lo dupliques).
# Conector de texto: 100% GRATUITO (Google News RSS / feeds públicos). Sin claves.
# Resiliencia de los conectores (reintentos + backoff exponencial).
HD_INGESTA_MAX_RETRIES=4
HD_INGESTA_BACKOFF_S=1.0
HD_INGESTA_TIMEOUT_S=30
# Ventana (segundos) para agrupar la transcripción de video.
HD_INGESTA_VENTANA_S=60
