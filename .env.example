# hd-scraper — configuración (todas opcionales; hay defaults para dev local)

# Base de datos. Fase 1: SQLite. El esquema es portable a PostgreSQL.
HD_DATABASE_URL=sqlite:///data/hd_scraper.db

# Retención del crudo comprimido en disco (días).
HD_RAW_RETENTION_DAYS=90

# Scheduler: cada cuántas horas corre.
HD_SCHEDULE_HOURS=12

# Gobernanza: rate limiting / backoff por fuente.
HD_REQUEST_TIMEOUT_S=20
HD_MAX_RETRIES=4
HD_BACKOFF_BASE_S=2
HD_MIN_INTERVAL_S=1.5

# Salud: fallos consecutivos que disparan alerta.
HD_HEALTH_ALERT_THRESHOLD=2

# Empresas seguidas por el scheduler (coma-separadas).
HD_TRACKED_EMPRESAS=

# Slugs de job boards por empresa: "Empresa=slug,Empresa2=slug2".
# El scheduler solo consulta job boards para empresas con slug configurado.
HD_TRACKED_SLUGS=

# User-Agent identificable.
HD_USER_AGENT=hd-scraper/0.1 (+https://hamaca.digital; evidence-extraction)
