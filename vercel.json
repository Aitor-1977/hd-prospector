{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "HD_DATABASE_URL": "sqlite:////tmp/hd_scraper.db",
    "HD_RAW_DIR": "/tmp/hd_raw"
  }
}
